{
  "name": "download-artifact",
  "version": "1.0.0",
  "private": true,
  "description": "Download an artifact from a GitHub workflow run",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benday-inc/download-artifact.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "Benjamin Day Consulting, Inc.",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2"
  },
  "overrides": {
    "@actions/http-client": "2.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.25.0",
    "eslint-plugin-github": "^4.4.0",
    "eslint-plugin-jest": "^27.1.3",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-ts": "^0.4.0",
    "jest": "^29.2.1",
    "jest-circus": "^29.2.1",
    "js-yaml": "^4.1.0",
    "prettier": "^2.7.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
